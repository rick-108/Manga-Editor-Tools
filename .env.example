# ======================================================
#  RTN Manga — متغيرات البيئة المطلوبة
#  انسخ هذه المفاتيح وضعها في Replit Secrets
#  (Secrets → لا تضعها في ملف .env مباشرة على Replit)
# ======================================================

# ✅ مطلوب — رابط قاعدة بيانات Neon (سحابية، لا تُفقد عند تغيير الحساب)
NEON_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ✅ مطلوب — مفتاح سري لتشفير جلسات المستخدمين (اكتب أي نص عشوائي طويل)
SESSION_SECRET=ضع_هنا_نصاً_عشوائياً_طويلاً

# 🔶 اختياري — مفتاح ImgBB لرفع صور الغلاف والصفحات (موصى به بشدة)
# احصل عليه من: https://api.imgbb.com
IMGBB_API_KEY=ضع_مفتاح_imgbb_هنا

# 🔶 اختياري — كلمة مرور لوحة الناشر (الافتراضي: rtn_publisher_2024)
PUBLISHER_CODE=ضع_كلمة_مرور_الناشر_هنا

# 🔶 اختياري — رمز الناشر Bearer (الافتراضي: rtn_publisher_secret_token)
PUBLISHER_TOKEN=ضع_رمز_الناشر_هنا
